# ==========================================
# Saju Monorepo .gitignore (workspace root)
# Java/Gradle (backend) + Node/Next.js (frontend) 통합
# ==========================================

# ---- macOS ----
.DS_Store
Thumbs.db

# ---- IDE / Editor ----
.idea/
.vscode/
*.iml
*.iws
*.ipr
*.swp
*.swo
*~

# ---- Java / Gradle (backend) ----
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/
# IntelliJ build output (root-level only — hexagonal 'adapter/out', 'port/out' 보존)
/out/
/backend/out/
/bin/
/backend/bin/
target/
generated/
*.jar
!gradle-wrapper.jar
*.class

# ---- Node / Next.js (frontend) ----
node_modules/
.next/
.turbo/
.vercel/
dist/
.cache/
*.tsbuildinfo
next-env.d.ts

# ---- Environment / Secrets ----
.env
.env.local
.env.*.local
!.env.example

# ---- Logs ----
logs/
*.log
*.pid
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---- Coverage / Tests ----
coverage/
.nyc_output/

# ---- Misc ----
*.tmp
*.bak
